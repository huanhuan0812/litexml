// litexml_export.h.in

#ifndef LITEXML_EXPORT_H
#define LITEXML_EXPORT_H

#ifdef _WIN32
    #ifdef LITEXML_EXPORTING
        #define LITEXML_API __declspec(dllexport)
    #else
        #define LITEXML_API __declspec(dllimport)
    #endif
#else
    #ifdef LITEXML_EXPORTING
        #define LITEXML_API __attribute__((visibility("default")))
    #else
        #define LITEXML_API
    #endif
#endif

// 静态库时不需要导出宏
#ifdef LITEXML_STATIC
    #undef LITEXML_API
    #define LITEXML_API
#endif

#endif // LITEXML_EXPORT_H