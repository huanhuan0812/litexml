# litexml-config.cmake.in

@PACKAGE_INIT@

# 获取安装路径
get_filename_component(LITEXML_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(LITEXML_INSTALL_PREFIX "${LITEXML_CMAKE_DIR}/../../../" ABSOLUTE)

# 设置包含路径
set(LITEXML_INCLUDE_DIR "${LITEXML_INSTALL_PREFIX}/include/litexml")

# 检查包含目录是否存在
if(NOT EXISTS "${LITEXML_INCLUDE_DIR}")
    set(LITEXML_FOUND FALSE)
    message(STATUS "litexml: Include directory not found at ${LITEXML_INCLUDE_DIR}")
    return()
endif()

# 查找库文件
find_library(LITEXML_LIBRARY
    NAMES litexml
    PATHS "${LITEXML_INSTALL_PREFIX}/lib"
    NO_DEFAULT_PATH
)

# 如果没找到，尝试在当前目录查找
if(NOT LITEXML_LIBRARY)
    find_library(LITEXML_LIBRARY
        NAMES litexml
        PATHS "${LITEXML_CMAKE_DIR}/../../"
        NO_DEFAULT_PATH
    )
endif()

# 检查库文件是否存在
if(NOT LITEXML_LIBRARY)
    set(LITEXML_FOUND FALSE)
    message(STATUS "litexml: Library not found")
    return()
endif()

# 设置库变量
set(LITEXML_LIBRARIES ${LITEXML_LIBRARY})

# 创建导入目标
if(NOT TARGET litexml::litexml)
    add_library(litexml::litexml UNKNOWN IMPORTED)
    set_target_properties(litexml::litexml PROPERTIES
        IMPORTED_LOCATION "${LITEXML_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${LITEXML_INCLUDE_DIR}"
        INTERFACE_COMPILE_DEFINITIONS "LITEXML_STATIC"
    )
endif()

# 设置版本
set(LITEXML_VERSION "@PROJECT_VERSION@")

# 处理查找结果
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(litexml
    REQUIRED_VARS LITEXML_INCLUDE_DIR LITEXML_LIBRARY
    VERSION_VAR LITEXML_VERSION
)

# 设置标志
set(LITEXML_FOUND ${LITEXML_FOUND})